generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  reseller
  user
}

enum ProxyStatus {
  active
  expired
  disabled
}

model User {
  id              String           @id @default(uuid()) @db.Uuid
  email           String           @unique
  password        String
  role            Role             @default(user)
  balance         Decimal          @default(0) @db.Decimal(20, 2)
  proxies         Proxy[]
  payments        Payment[]
  resellerPricing ResellerPricing?
  createdAt       DateTime         @default(now()) @map("created_at")

  @@map("users")
}

model Proxy {
  id         String      @id @default(uuid()) @db.Uuid
  serverIp   String?     @map("server_ip")
  proxyIp    String      @map("proxy_ip")
  port       Int
  username   String
  password   String
  type       String      @default("http")
  status     ProxyStatus @default(active)
  country    String?     @default("Unknown")
  latency    Int?
  expiresAt  DateTime?   @map("expires_at")
  assignedTo String?     @db.Uuid @map("assigned_to")
  user       User?       @relation(fields: [assignedTo], references: [id])
  createdAt  DateTime    @default(now()) @map("created_at")

  @@map("proxies")
}

model Payment {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid @map("user_id")
  user          User     @relation(fields: [userId], references: [id])
  amount        Decimal  @db.Decimal(20, 2)
  provider      String
  status        String
  transactionId String?  @map("transaction_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("payments")
}

model ResellerPricing {
  id            String  @id @default(uuid()) @db.Uuid
  userId        String  @unique @db.Uuid @map("user_id")
  user          User    @relation(fields: [userId], references: [id])
  pricePerProxy Decimal @db.Decimal(20, 2) @map("price_per_proxy")

  @@map("reseller_pricing")
}
